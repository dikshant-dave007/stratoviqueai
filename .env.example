# ─────────────────────────────────────────────────
# StratoviqueAI — Environment Variables
# Copy this file:  copy .env.example .env
# Then fill in your real API keys below.
# ─────────────────────────────────────────────────

# [REQUIRED] Google Gemini
# Get your free key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_key_here

# Gemini model to use (flash = fast/cheap, pro = best quality)
GEMINI_MODEL=gemini-2.0-flash

# [REQUIRED] Serper — for Market Research Agent
# Already have your key → paste it here
SERPER_API_KEY=your_serper_key_here

# [OPTIONAL] LangSmith — full agent tracing (highly recommended)
# Get free key → https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=stratoviqueai

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
